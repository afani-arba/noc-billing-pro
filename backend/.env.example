# NOC-Billing-Pro — Backend Environment Configuration
# cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017/nocbillingpro
MONGO_DB_NAME=nocbillingpro

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=GANTI_DENGAN_SECRET_KEY_64_KARAKTER_RANDOM

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*

# ── Nama Layanan ──────────────────────────────────────────────────────────────
NOC_SERVICE_NAME=NOC Billing Pro

# ── Edition (JANGAN UBAH) ─────────────────────────────────────────────────────
# billing_pro = NOC-Billing-Pro (GenieACS + BGP + Billing, tanpa SD-WAN)
# License key format: ArBa-BP-XXXX-XXXX
APP_EDITION=billing_pro

# ── Syslog ────────────────────────────────────────────────────────────────────
SYSLOG_HOST=0.0.0.0
SYSLOG_PORT=5142
ENABLE_SYSLOG=true

# ── Polling ───────────────────────────────────────────────────────────────────
ENABLE_POLLING=true

# ── Billing ───────────────────────────────────────────────────────────────────
ENABLE_BILLING_SCHEDULER=true
ENABLE_ISOLIR=true
ENABLE_HOTSPOT_CLEANUP=true

# ── RADIUS Server ─────────────────────────────────────────────────────────────
# Secret harus sama dengan yang dikonfigurasi di MikroTik
# VPS terpisah → port 1812 (ubah docker-compose.yml)
# VPS sama NOC-Sentinel → port 1816 (default docker-compose.yml)
RADIUS_SECRET=ganti_ini_dengan_secret_radius_anda

# ── SNMP ──────────────────────────────────────────────────────────────────────
ENABLE_SNMP_POLLER=true
SNMP_POLL_INTERVAL=90

# ── Session Cache ─────────────────────────────────────────────────────────────
ENABLE_SESSION_CACHE=true

# ── Speedtest ─────────────────────────────────────────────────────────────────
ENABLE_SPEEDTEST=true

# ── GenieACS (TR-069 / ZTP) ──────────────────────────────────────────────────
# URL mengarah ke container genieacs-nbi (internal docker network)
ENABLE_GENIEACS_SYNC=true
GENIEACS_URL=http://genieacs-nbi:7557
GENIEACS_USERNAME=admin
GENIEACS_PASSWORD=admin

# ── Peering Eye + BGP Content Steering ───────────────────────────────────────
ENABLE_BGP_STEERING=true
# GoBGP berjalan di HOST Ubuntu (bukan container)
# 172.17.0.1 = docker bridge gateway (default)
# Jalankan: sudo bash gobgp/install-gobgp.sh
GOBGPD_HOST=172.17.0.1

# ── Features DISABLED di Billing Pro ─────────────────────────────────────────
ENABLE_ROUTE_OPTIMIZER=false
ENABLE_NETWATCH_POLLER=false
ENABLE_NETFLOW=false

# ── License Server ────────────────────────────────────────────────────────────
LICENSE_SERVER_URL=https://license.arbatraining.com

# ── Moota (Payment Gateway) ──────────────────────────────────────────────────
MOOTA_API_KEY=
MOOTA_WEBHOOK_SECRET=

# ── WhatsApp / Fonnte (CS Command Center) ────────────────────────────────────
FONNTE_TOKEN=
WA_NUMBER=

# ── Firebase Push Notification ────────────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=/app/firebase-service-account.json

# ── n8n Integration (Integrasi & Otomasi) ────────────────────────────────────
N8N_WEBHOOK_URL=

# ── Payment Gateway Multi-Provider ───────────────────────────────────────────
# Aktifkan di UI: Billing → Pengaturan → Payment Gateway

# Xendit (Virtual Account + QRIS + E-Wallet)
# Daftar di: https://xendit.co → Settings → API Keys
# Webhook URL: https://[domain]/api/webhook/xendit
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=
# Bank VA default: BNI | BCA | BRI | MANDIRI | PERMATA | BSI
XENDIT_VA_BANK=BNI

# BCA SNAP API (Virtual Account BCA)
# PERHATIAN: Memerlukan kontrak resmi dengan BCA Developer Portal
# Webhook URL: https://[domain]/api/webhook/bca
BCA_CLIENT_ID=
BCA_CLIENT_SECRET=
BCA_COMPANY_CODE=
BCA_API_KEY=
BCA_API_SECRET=

# BRI BRIVA (Virtual Account BRI)
# PERHATIAN: Memerlukan kontrak resmi dengan BRI Partner Portal
# Webhook URL: https://[domain]/api/webhook/bri
BRI_CLIENT_ID=
BRI_CLIENT_SECRET=
BRI_INSTITUTION_CODE=
